modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 25196
externalPort = 3000

[userenv]

[userenv.shared]
JWT_SECRET = "t4Kd4xGcqU3vfK4zS6lxUc198p1GVZbQZYoT/zfFEUpjNJA4DmdxA04Uu6zsCcSQ"
DEFAULT_ADMIN_PASSWORD = "admin@123"
DEFAULT_HOST_PASSWORD = "host@123"
